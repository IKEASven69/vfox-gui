{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vfox-gui",
  "version": "0.2.1",
  "identifier": "com.vfox.gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vfox — 版本管理器",
        "width": 1100,
        "height": 640,
        "minWidth": 760,
        "minHeight": 460
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {}
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/IKEASven69/vfox-gui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNkI0NEYzNUEzQkFDNDkKUldSSnJEdGE4MFJycm40Uk5CUUN2c3M5cnB4VGFIdWJxeEFXU01KTFRXRmtmWHU2dUlNZWxzejkK",
      "dialog": true
    }
  }
}
